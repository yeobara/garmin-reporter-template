# 가민 계정 (Garmin Connect 로그인 정보)
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# Gemini API 키 (https://aistudio.google.com)
GEMINI_API_KEY=AIza...

# Resend API 키 (https://resend.com)
RESEND_API_KEY=re_...

# 리포트 받을 이메일 주소
# ※ Resend 무료 플랜은 Resend에 가입한 이메일로만 발송 가능
REPORT_TO=your_email@example.com
